{
  "name": "pi-subagent-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "MCP server that lets Claude Code delegate bounded coding tasks to Pi (pi --mode rpc), with git worktree isolation and compact diff/summary results.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
